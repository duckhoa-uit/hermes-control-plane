# /etc/hermes-control-plane/launcher.env — owned by hermes-cp:hermes-cp, mode 0600.
# Source these into your shell before running the launcher manually, or let
# systemd load the file via EnvironmentFile=.

# ---- E2B ----
E2B_API_KEY=e2b_REPLACE_ME
E2B_TEMPLATE=control-plane-runner

# ---- Z.AI (OpenCode LLM provider) ----
ZAI_API_KEY=REPLACE_ME

# ---- GitHub single-user OAuth — PR `author` = real user ----
# Fine-grained PAT, Contents+PullRequests Read & write. Rotate quarterly.
# Also used by the launcher to read PR head.ref from GitHub when an
# amend session is spawned (so amend-of-amend follows the original PR
# branch instead of session.branch). Read access on PullRequests is
# sufficient for that.
HERMES_GITHUB_WRITE_TOKEN=github_pat_REPLACE_ME
# B3: read-only PAT (Contents: Read) baked into sandbox origin remote.
HERMES_GITHUB_READ_TOKEN=github_pat_REPLACE_ME
GITHUB_USER_LOGIN=your-github-handle
# Optional. Defaults to <login>@users.noreply.github.com.
GITHUB_USER_EMAIL=you@example.com

# ---- Wire to the deployed Worker ----
CONTROL_PLANE_BASE_URL=https://hermes-control-plane.duckhoa-dev.workers.dev
# Shared secret authenticating launcher → Worker calls to /pr-index. Must match
# the Worker's HERMES_LAUNCHER_SECRET secret.
HERMES_LAUNCHER_SECRET=REPLACE_ME

# ---- Launcher itself ----
CONTROL_PLANE_LAUNCHER_PORT=8789
MAX_CONCURRENT_SESSIONS=10
CONTROL_PLANE_AUTO_PR=1

# ---- PR authority model (PR #A wiring; PR #B reads this) ----
# When "launcher", the launcher accepts POST /sessions/:id/publish-pr
# and performs the `git push` + `POST /pulls` on behalf of the
# sandbox runner. When "legacy" (default), the in-sandbox runner does
# both itself (today's behaviour). Flip together with the Worker's
# HERMES_PUBLISH_VIA_LAUNCHER var.
HERMES_PR_AUTHORITY_MODE=legacy

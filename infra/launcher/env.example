# /etc/hermes/launcher.env — owned by hermes:hermes, mode 0600.
# Source these into your shell before running the launcher manually, or let
# systemd load the file via EnvironmentFile=.

# ---- E2B ----
E2B_API_KEY=e2b_REPLACE_ME
E2B_TEMPLATE=hermes-runner

# ---- Z.AI (OpenCode LLM provider) ----
ZAI_API_KEY=REPLACE_ME
ZAI_MODEL=glm-5.2

# ---- GitHub App (bot fallback identity + repo metadata) ----
GITHUB_APP_ID=REPLACE_ME
GITHUB_PRIVATE_KEY_FILE=/etc/hermes/app.pkcs8.pem
# OR inline (newlines kept):
# GITHUB_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----

# ---- P1.1 single-user OAuth — PR `author` = real user ----
# Fine-grained PAT, Contents+PullRequests Read & write. Rotate quarterly.
GITHUB_USER_TOKEN=github_pat_REPLACE_ME
GITHUB_USER_LOGIN=your-github-handle
# Optional. Defaults to <login>@users.noreply.github.com.
GITHUB_USER_EMAIL=you@example.com

# ---- Wire to the deployed Worker ----
HERMES_BASE_URL=https://hermes-control-plane.duckhoa-dev.workers.dev
HERMES_PUBLIC_URL=https://hermes-control-plane.duckhoa-dev.workers.dev

# ---- Launcher itself ----
HERMES_LAUNCHER_PORT=8789
MAX_CONCURRENT_SESSIONS=10
HERMES_AUTO_PR=1

# /etc/hermes-control-plane/launcher.env — owned by hermes-cp:hermes-cp, mode 0600.
# Source these into your shell before running the launcher manually, or let
# systemd load the file via EnvironmentFile=.

# ---- E2B ----
E2B_API_KEY=e2b_REPLACE_ME
E2B_TEMPLATE=control-plane-runner

# ---- Z.AI (OpenCode LLM provider) ----
ZAI_API_KEY=REPLACE_ME

# ---- GitHub single-user OAuth — PR `author` = real user ----
# Two fine-grained PATs.  Both scoped to the repos Hermes operates on.
# Rotate quarterly.
#
#   GITHUB_WRITE_TOKEN — Contents + Pull-requests Read & Write.
#     LAUNCHER-SIDE ONLY.  Never enters the sandbox.  Used by the
#     launcher's POST /sessions/:id/publish-pr to push the branch +
#     open the PR.  Also used by the launcher to read PR head.ref from
#     GitHub when an amend session is spawned (so amend-of-amend
#     follows the original PR branch instead of session.branch).
#
#   GITHUB_READ_TOKEN  — Contents: Read only.
#     Baked into the sandbox's .git/config so clone + fetch work; the
#     agent cannot push (GitHub returns 403 on the read-only PAT).
GITHUB_WRITE_TOKEN=github_pat_REPLACE_ME
GITHUB_READ_TOKEN=github_pat_REPLACE_ME
GITHUB_USER_LOGIN=your-github-handle
# Optional. Defaults to <login>@users.noreply.github.com.
GITHUB_USER_EMAIL=you@example.com

# ---- Wire to the deployed Worker ----
WORKER_BASE_URL=https://hermes-control-plane.duckhoa-dev.workers.dev
# Shared secret authenticating launcher → Worker calls to /pr-index. Must match
# the Worker's LAUNCHER_SHARED_SECRET secret.
LAUNCHER_SHARED_SECRET=REPLACE_ME

# ---- Launcher itself ----
LAUNCHER_PORT=8789
MAX_CONCURRENT_SESSIONS=10
AUTO_CREATE_PR=1


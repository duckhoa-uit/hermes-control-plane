# ---- E2B Sandbox (lấy free tại https://e2b.dev/dashboard) ----
E2B_API_KEY=

# ---- Zai (z.ai) LLM Provider ----
# OpenCode hỗ trợ provider `zai-coding-plan` natively (endpoint
# https://api.z.ai/api/coding/paas/v4). Chỉ cần API key + model id.
ZAI_API_KEY=
ZAI_MODEL=glm-5.2

# ---- GitHub App (optional, chỉ cần khi test PR thật) ----
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# ---- E2B Sandbox (lấy free tại https://e2b.dev/dashboard) ----
E2B_API_KEY=

# ---- Zai (z.ai) LLM Provider ----
# OpenCode hỗ trợ provider `zai-coding-plan` natively (endpoint
# https://api.z.ai/api/coding/paas/v4).
ZAI_API_KEY=

# ---- GitHub single-user OAuth (P1.1, required for opening PRs) ----
# Fine-grained PAT, Contents + Pull-requests read & write.
HERMES_GITHUB_WRITE_TOKEN=
GITHUB_USER_LOGIN=
# Optional. Defaults to <login>@users.noreply.github.com.
GITHUB_USER_EMAIL=

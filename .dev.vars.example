# Hermes Control Plane — Environment Variables
# Copy to .dev.vars and fill in the values.

# GitHub
GITHUB_WRITE_TOKEN=ghp_...
GITHUB_READ_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=...
GITHUB_USER_LOGIN=your-github-username
GITHUB_OWNER=
GITHUB_REPO=

# LLM Model (provider/model format, e.g. anthropic/claude-sonnet-4-6)
LLM_MODEL=anthropic/claude-sonnet-4-6

# PostHog (optional analytics)
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_TOKEN=

# Auto-fix limits
AUTOFIX_CAP_PER_PR=3
MAX_CONCURRENT_SESSIONS=10
AUTO_CREATE_PR=1

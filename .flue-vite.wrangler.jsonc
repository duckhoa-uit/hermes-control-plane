{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hermes-control-plane",
  "main": ".flue-vite/_entry.ts",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./src/cf-sandbox/Dockerfile",
      "instance_type": "standard-1",
      "max_instances": 10
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "Sandbox"
      },
      {
        "name": "PR_INDEX_DO",
        "class_name": "PrIndexDurableObject"
      },
      {
        "name": "APPROVAL_DO",
        "class_name": "ApprovalDurableObject"
      },
      {
        "name": "FlueRegistry",
        "class_name": "FlueRegistry"
      },
      {
        "name": "FLUE_HERMES_AGENT",
        "class_name": "FlueHermesAgent"
      },
      {
        "name": "FLUE_REGISTRY",
        "class_name": "FlueRegistry"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox", "PrIndexDurableObject", "FlueRegistry", "FlueHermesAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ApprovalDurableObject"]
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "LLM_MODEL": "zai/glm-5.2",
    "POSTHOG_HOST": "https://us.i.posthog.com",
    "AUTOFIX_CAP_PER_PR": "3",
    "MAX_CONCURRENT_SESSIONS": "10",
    "AUTO_CREATE_PR": "1",
    "WORKER_URL": "http://localhost:8799"
  }
}

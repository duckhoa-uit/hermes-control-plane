// Dev container for hermes-control-plane.
//
// Spec: https://containers.dev/implementors/json_reference/
//
// Why ship one:
//   - Codespaces / VS Code Remote-Containers / Cursor open this repo
//     in a one-click-reproducible env with Bun, Node, and the editor
//     extensions our toolchain needs (Biome, Oxlint, Cloudflare/Workers).
//   - Autonomous agents that boot a container to work on the repo get
//     the same shape as a human contributor; they read AGENTS.md +
//     CONTRIBUTING.md and run the same `bun run setup` bootstrap.
//
// What is preinstalled:
//   - Node 22 (matches the E2B sandbox interior, see README §Tech stack)
//   - Bun (the canonical package manager; lockfile is bun.lock)
//   - GitHub CLI (used by docs/DEPLOYMENT.md and several scripts)
//   - Editor extensions for the linter (Oxlint), formatter (Biome),
//     editor settings (EditorConfig), and the Cloudflare Workers runtime.
//
// What runs automatically:
//   - `bun install --frozen-lockfile` once after the container is built.
//   - `bun run setup` after the workspace is attached (idempotent: copies
//     `.dev.vars.example` to `.dev.vars` if missing, runs lint + typecheck
//     + tests so the first prompt the agent sees in the terminal is the
//     project's actual state).
//
// What is forwarded:
//   - 8787 (wrangler dev)
//   - 8789 (launcher sidecar)
{
  "name": "hermes-control-plane",

  // Microsoft TypeScript-Node base image: Debian + Node 22 + git + zsh.
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",

  "features": {
    // Bun is the package manager + script runner; install latest.
    "ghcr.io/shyim/devcontainers-features/bun:0": {
      "version": "latest"
    },
    // GitHub CLI — used by deployment runbook + several scripts that
    // open PRs / inspect runs.
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },

  // Run once after the container is built. `bun install --frozen-lockfile`
  // mirrors CI exactly (lint.yml step `bun install --frozen-lockfile`).
  "postCreateCommand": "bun install --frozen-lockfile",

  // Run every time the workspace is attached. `bun run setup` is the
  // idempotent bootstrap defined in package.json — verifies tooling,
  // copies .dev.vars.example -> .dev.vars if missing, runs lint +
  // typecheck + tests.
  "postAttachCommand": "bun run setup",

  // Worker dev (`bun run dev` → wrangler dev) and launcher sidecar
  // (`bun run launcher`).
  "forwardPorts": [8787, 8789],
  "portsAttributes": {
    "8787": {
      "label": "Worker (wrangler dev)",
      "onAutoForward": "silent"
    },
    "8789": {
      "label": "Launcher sidecar",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        // TypeScript first-party (already enabled, listed for explicitness).
        "ms-vscode.vscode-typescript-next",
        // Biome — the formatter (lint disabled in biome.json so oxlint owns it).
        "biomejs.biome",
        // Oxlint — the linter, runs as a CI gate.
        "oxc.oxc-vscode",
        // EditorConfig — picks up tab/space + final-newline rules.
        "editorconfig.editorconfig",
        // Cloudflare Workers runtime hints (typings + wrangler awareness).
        "cloudflare.vscode-cloudflare-workers"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "editor.codeActionsOnSave": {
          // Run oxlint --fix on save for the affordances oxlint can
          // safely autofix; CI still runs the unfixed check.
          "source.fixAll.oxc": "explicit"
        },
        "[typescript]": { "editor.defaultFormatter": "biomejs.biome" },
        "[typescriptreact]": { "editor.defaultFormatter": "biomejs.biome" },
        "[json]": { "editor.defaultFormatter": "biomejs.biome" },
        "[jsonc]": { "editor.defaultFormatter": "biomejs.biome" },
        "files.eol": "\n"
      }
    }
  },

  // Tell git inside the container to trust the workspace mount (Codespaces
  // mounts as a different user than the one git was configured for).
  "containerEnv": {
    "GIT_CONFIG_GLOBAL": "/dev/null"
  },

  // Don't run as root — keeps file ownership sane on Linux hosts.
  "remoteUser": "node"
}

{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hermes-control-plane",
  "main": ".flue-vite/_entry.ts",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [{ "pattern": "control-plan.khoa.lol", "custom_domain": true }],
  "observability": { "enabled": true, "head_sampling_rate": 0.1 },
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./src/cf-sandbox/Dockerfile",
      "instance_type": "standard-1",
      "max_instances": 10
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "Sandbox", "class_name": "Sandbox" },
      { "name": "PR_INDEX_DO", "class_name": "PrIndexDurableObject" },
      { "name": "APPROVAL_DO", "class_name": "ApprovalDurableObject" },
      { "name": "CONTROL_PLAN_TASK_DO", "class_name": "ControlPlanTaskDurableObject" },
      { "name": "CONTROL_PLAN_ADMISSION_DO", "class_name": "ControlPlanAdmissionDurableObject" },
      { "name": "FlueRegistry", "class_name": "FlueRegistry" },
      { "name": "FLUE_CONTROL_PLAN_AGENT", "class_name": "FlueControlPlanAgent" },
      { "name": "FLUE_REGISTRY", "class_name": "FlueRegistry" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox", "PrIndexDurableObject", "FlueRegistry", "FlueHermesAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ApprovalDurableObject"]
    },
    {
      "tag": "v3-control-plan-agent-rename",
      "renamed_classes": [{ "from": "FlueHermesAgent", "to": "FlueControlPlanAgent" }]
    },
    {
      "tag": "v4-control-plan-task-do",
      "new_sqlite_classes": ["ControlPlanTaskDurableObject"]
    },
    {
      "tag": "v5-control-plan-admission-do",
      "new_sqlite_classes": ["ControlPlanAdmissionDurableObject"]
    }
  ],
  "ai": { "binding": "AI" },
  "vars": {
    "LLM_MODEL": "zai/glm-5.2",
    "POSTHOG_HOST": "https://us.i.posthog.com",
    "AUTOFIX_CAP_PER_PR": "3",
    "MAX_CONCURRENT_SESSIONS": "10",
    "AUTO_CREATE_PR": "1",
    "SANDBOX_TRANSPORT": "rpc",
    "APPROVAL_MODE": "policy"
  }
}

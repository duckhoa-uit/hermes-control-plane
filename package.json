{
  "name": "hermes-control-plane",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "bash scripts/dev-setup.sh",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "CI=1 vitest run --coverage",
    "deadcode": "knip",
    "prepare": "husky",
    "bundle:size": "bun run scripts/bundle-size.ts",
    "flags:check": "bun run scripts/detect-dead-flags.ts",
    "dupes": "jscpd"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.7.0",
    "@flue/github": "1.0.0-beta.1",
    "@flue/runtime": "1.0.0-beta.7",
    "@flue/sdk": "1.0.0-beta.7",
    "@octokit/rest": "^22.0.0",
    "agents": "^0.14.0",
    "hono": "^4.7.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "3.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0",
    "knip": "^6.21.0",
    "jscpd": "^5.0.11"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,jsonc,md}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx,js,mjs}": [
      "oxlint --fix"
    ]
  }
}

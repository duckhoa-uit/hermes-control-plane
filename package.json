{
  "name": "hermes-control-plane",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute hermes-db --local --file=schema.sql",
    "db:query": "wrangler d1 execute hermes-db --local --command",
    "api": "bun run src/testing/api-client.ts",
    "fake-runner": "bun run src/testing/fake-runner.ts",
    "template:build": "bun run infra/e2b/build-template.ts",
    "launch": "bun run scripts/launch-session.ts",
    "launcher": "bun run src/launcher/server.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.17.10",
    "e2b": "^2.30.5",
    "ws": "^8.21.0"
  }
}

{
  "name": "hermes-control-plane",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "setup": "bash scripts/dev-setup.sh",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "deadcode": "knip --include files,dependencies,binaries,unlisted,exports,nsExports,duplicates --no-config-hints",
    "deadcode:report": "knip",
    "dupes": "jscpd --threshold 4",
    "bundle:size": "bun run scripts/bundle-size.ts",
    "flags:check": "bun run scripts/detect-dead-flags.ts",
    "agents:check": "bun run scripts/validate-agents-md.ts",
    "openapi:check": "bun run scripts/validate-openapi.ts",
    "api": "bun run src/testing/api-client.ts",
    "fake-runner": "bun run src/testing/fake-runner.ts",
    "template:build": "bun run infra/e2b/build-template.ts",
    "launch": "bun run scripts/launch-session.ts",
    "launcher": "bun run src/launcher/server.ts",
    "e2e:real": "bun run scripts/e2e-real.ts",
    "e2e:full": "bun run scripts/e2e-full.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "knip": "^6.21.0",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "1.17.10",
    "e2b": "^2.30.5",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,jsonc,md}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx,js,mjs}": [
      "oxlint --fix"
    ]
  }
}
